rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Firestore Security Rules
// ─────────────────────────────────────────────────────────────────────────────
//
// These rules lock down the database completely from client-side access.
// All reads and writes go through Cloud Functions (server-side admin SDK),
// which bypasses these rules entirely.
//
// IMPORTANT: Never grant client-side read/write access to:
//   - contactSubmissions   (raw form submissions)
//   - submission_logs      (security audit trail)
//   - _ratelimit           (rate limit counters)
//
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny all client-side access.
    // Cloud Functions use the Admin SDK and bypass these rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
