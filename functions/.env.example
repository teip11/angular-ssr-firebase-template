# ════════════════════════════════════════════════════════════════════
# [TEMPLATE] Cloud Functions — Environment Variables
# ════════════════════════════════════════════════════════════════════
#
# HOW TO USE:
#   1. Copy this file to functions/.env
#   2. Fill in your real values
#   3. NEVER commit .env — it is already in .gitignore
#
# For PRODUCTION: use Firebase Secret Manager for sensitive values:
#   firebase functions:secrets:set RECAPTCHA_SECRET
#   firebase functions:secrets:set GMAIL_APP_PASSWORD
#   firebase functions:secrets:set HUBSPOT_TOKEN
#
# Non-sensitive values can stay in apphosting.yaml (env section).
# ════════════════════════════════════════════════════════════════════

# ── CORS ─────────────────────────────────────────────────────────────
# Your production domain — requests from other origins are blocked.
# Example: https://glowseoul.com
ALLOWED_ORIGIN=https://YOUR_DOMAIN.com

# ── Email (non-secret) ───────────────────────────────────────────────
# Email address that receives lead notifications.
OWNER_EMAIL=hello@YOUR_DOMAIN.com

# Sender address — must be the Gmail account you authenticate with.
# (or your SendGrid verified sender)
CONTACT_FROM_EMAIL=hello@YOUR_DOMAIN.com

# Your brand name — appears in email templates.
SITE_NAME=Your Site Name

# ── Firebase Secrets (for local dev only — use Firebase CLI in production) ──
# In production set these with: firebase functions:secrets:set <NAME>
# Locally you can put them here for the emulator to pick up.

# Google reCAPTCHA v3 — server-side secret key
# Get at: https://www.google.com/recaptcha/admin/create
# Choose "Score based (v3)" — copy the SECRET key (not the site key)
RECAPTCHA_SECRET=YOUR_RECAPTCHA_SECRET_KEY

# Gmail App Password — NOT your regular Gmail password.
# Enable 2FA → https://myaccount.google.com/apppasswords → create "Mail" password
# Use the 16-character password here.
GMAIL_APP_PASSWORD=YOUR_16_CHAR_APP_PASSWORD

# HubSpot Private App Token — optional CRM integration.
# Create at: HubSpot → Settings → Integrations → Private Apps
# Leave blank to disable HubSpot push.
HUBSPOT_TOKEN=
