# ──────────────────────────────────────────────
# Gehrke Studio — .gitignore
# ──────────────────────────────────────────────

# Dependencies
node_modules/
functions/node_modules/
functions/lib/

# Build output
dist/
.angular/

# Environment / secrets — NEVER commit these
.env
.env.local
.env.*.local
*.env
functions/.env
functions/.env.local
**/.env
**/.env.local
**/.env.*.local

# Firebase secrets & service account keys
firebase-adminsdk*.json
*-firebase-adminsdk-*.json
service-account*.json
serviceAccount*.json
google-services.json
GoogleService-Info.plist

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
pubsub-debug.log
database-debug.log
hosting-debug.log

# OS / IDE
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo

# Test coverage
coverage/

# Temporary / scratch files
temp_stitch/
*.tmp
*.bak
*.orig

# Package manager lock files (keep package-lock.json, ignore others)
yarn.lock
pnpm-lock.yaml
